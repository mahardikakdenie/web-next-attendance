# Application Configuration
# APP_URL must match your frontend domain (for origin checks)
APP_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL is used at build time for the client-side bundle
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Backend Proxy Configuration (Next.js Server Side)
# API_URL is the base URL of your Go/Backend service
API_URL=http://your-backend-url:8080
INTERNAL_SECRET=your-internal-secret
SIGN_SECRET=your-signature-secret

# Server/Docker Configuration
NODE_ENV=development
# Internal port the app listens on inside container
PORT=3000
# External port exposed on the host machine
HOST_PORT=9001
